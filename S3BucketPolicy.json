{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Principal": {
        "Service": "logs.ap-south-1.amazonaws.com"
      },
      "Action": "s3:GetBucketAcl",
      "Resource": "arn:aws:s3:::kdnews3bucket"
    },
    {
      "Effect": "Allow",
      "Principal": {
        "Service": "logs.ap-south-1.amazonaws.com"
      },
      "Action": "s3:PutObject",
      "Resource": "arn:aws:s3:::kdnews3bucket/*",
      "Condition": {
        "StringEquals": {
          "aws:SourceAccount": "764214840720",
          "s3:x-amz-acl": "bucket-owner-full-control"
        }
      }
    }
  ]
}